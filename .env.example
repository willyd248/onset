# Supabase — create a project at https://supabase.com
# Copy these from Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Without these vars the app falls back to localStorage-only mode (no cloud sync)

# PostHog — create a project at https://posthog.com
VITE_POSTHOG_KEY=phc_your_project_api_key

# Sentry — create a project at https://sentry.io
VITE_SENTRY_DSN=https://your-key@o0000000.ingest.sentry.io/0000000

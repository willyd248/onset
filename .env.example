# Supabase — create a project at https://supabase.com
# Copy these from Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Without these vars the app falls back to localStorage-only mode (no cloud sync)

# Dev bypass secret — set this to a strong random string in production Vercel env vars
# Activate dev mode: ?dev=<your-secret>   Deactivate: ?dev=off
VITE_DEV_SECRET=your-dev-secret-here

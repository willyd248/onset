# Supabase — create a project at https://supabase.com
# Copy these from Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Without these vars the app falls back to localStorage-only mode (no cloud sync)

# PostHog — product analytics (optional, get key from posthog.com)
VITE_POSTHOG_KEY=phc_your_key_here
